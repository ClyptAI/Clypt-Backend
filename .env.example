# Copy this file to `.env.local` or export the variables in your shell.
# Do not commit real secrets.

# ----------------------------
# Frontend <-> backend API
# ----------------------------
CLYPT_FRONTEND_ORIGINS=http://localhost:8080,http://localhost:3000,http://localhost:5173
CLYPT_ONBOARDING_STATE_ROOT=
CLYPT_CREATOR_STORE_ROOT=
CLYPT_RETRIEVE_CANDIDATES_PATH=

# ----------------------------
# YouTube + Senso onboarding
# Required for real creator-profile analysis:
# - SENSO_API_KEY
# - SENSO_CREATOR_PROFILE_PROMPT_ID
# YOUTUBE_API_KEY is optional for handle/url-based lookup, but required for
# richer search/comments/statistics paths elsewhere in the repo.
# ----------------------------
YOUTUBE_API_KEY=
SENSO_API_KEY=
SENSO_CREATOR_PROFILE_PROMPT_ID=
SENSO_CREATOR_PROFILE_TEMPLATE_ID=
SENSO_CREATOR_PROFILE_MAX_VIDEOS=6
SENSO_CREATOR_PROFILE_MAX_RESULTS=8
SENSO_API_BASE_URL=https://apiv2.senso.ai/api/v1
SENSO_TIMEOUT_SECONDS=30

# ----------------------------
# Google / storage / remote Phase 1
# ----------------------------
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_PROJECT=
GCS_BUCKET=
DO_PHASE1_BASE_URL=
PHASE1_SERVICE_URL=
DIGITALOCEAN_PHASE1_BASE_URL=
DO_PHASE1_POLL_INTERVAL_SECONDS=10
DO_PHASE1_TIMEOUT_SECONDS=3600

# ----------------------------
# Pipeline runtime toggles
# ----------------------------
START_FROM=1
VIDEO_GCS_URI=
FFMPEG_REENCODE_CRF=15
FFMPEG_REENCODE_PRESET=slow
REMOTION_CRF=16
REMOTION_X264_PRESET=slow

# ----------------------------
# Crowd Clip / trend trim
# ----------------------------
CROWD_CLIP_RELEVANCE_PAGES=3
CROWD_CLIP_TIME_PAGES=2
CROWD_AUDIO_LEDGER_PATH=
CROWD_NODES_PATH=
TREND_TRIM_WATCHLIST=
TREND_TRIM_REGION=US
TREND_TRIM_GOOGLE_TRENDS_LIMIT=20
TREND_TRIM_YOUTUBE_POPULAR_LIMIT=20
TREND_TRIM_WATCHLIST_SEARCH_LIMIT=5

# ----------------------------
# Caption payload tools
# ----------------------------
CAPTION_MAX_WORDS=4
CAPTION_MAX_CHARS=28
CAPTION_GAP_MS=300
CAPTION_PAYLOAD_INPUT_PATH=
CAPTION_AUDIO_LEDGER_PATH=
CAPTION_PAYLOAD_OUTPUT_PATH=
TOP_CAPTION_PAYLOAD_INPUT_PATH=
TOP_CAPTION_NODES_PATH=
TOP_CAPTION_PAYLOAD_OUTPUT_PATH=
TOP_CAPTION_STYLE_HINT=
TOP_CAPTION_STYLE_PATH=

# ----------------------------
# Phase 1 yt-dlp / runtime prefs
# ----------------------------
YTDLP_VIDEO_FORMAT=
YTDLP_H264_PREFERRED_FORMAT=
YTDLP_MIN_LONG_EDGE=1080
ALLOW_LOW_RES_VIDEO=0
PHASE1_RUNTIME_PROFILE=production
PHASE1_FORCE_LRASD=0
PHASE1_SPEAKER_BINDING_MODE=auto
PHASE1_TRACKING_MODE=direct
PHASE1_TRACKER_BACKEND=botsort_reid
PHASE1_SHARED_ANALYSIS_PROXY=1
PHASE1_HEURISTIC_BINDING_ENABLED=
CLYPT_RUN_TALKNET_REFINEMENT=0

# ----------------------------
# DigitalOcean Phase 1 service
# Only needed on the worker/service host.
# ----------------------------
DO_PHASE1_STATE_ROOT=
DO_PHASE1_DB_PATH=
DO_PHASE1_OUTPUT_ROOT=
DO_PHASE1_LOG_ROOT=
DO_PHASE1_LOG_LEVEL=INFO
DO_PHASE1_WORKER_CONCURRENCY=1
DO_PHASE1_WORKER_ID=
DO_PHASE1_GPU_SLOTS=1
DO_PHASE1_GPU_SLOT_POLL_INTERVAL_S=0.1
DO_PHASE1_RUNNING_STALE_AFTER_SECONDS=1800
DO_PHASE1_HEARTBEAT_INTERVAL_SECONDS=30
DO_PHASE1_LOOP_ERROR_BACKOFF_SECONDS=2
DO_PHASE1_DASHBOARD_REMOTE_BASE_URL=
DO_PHASE1_HOST_LOCK_PATH=
DO_REGION=

# ----------------------------
# Optional Phase 1 worker tuning
# These are advanced knobs; leave unset unless you are actively tuning.
# See docs/setup/environment-variables.md for the full grouped inventory.
# ----------------------------
CLYPT_SPEAKER_BINDING_MODE=
CLYPT_TRACKING_MODE=
CLYPT_TRACKER_BACKEND=
CLYPT_TRACK_CHUNK_WORKERS=
CLYPT_LRASD_BATCH_SIZE=
CLYPT_LRASD_PIPELINE_OVERLAP=
CLYPT_LRASD_MAX_INFLIGHT=
CLYPT_EXPERIMENT_LOCAL_CLIP_BINDINGS=
CLYPT_ANALYSIS_PROXY_ENABLE=
CLYPT_AUDIO_DIARIZATION_ENABLE=
