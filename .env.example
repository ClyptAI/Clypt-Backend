# Refactored V3.1 backend only.
# Copy to `.env.local` if you want to override local defaults.

# Root directory for Phase 1-4 run artifacts.
CLYPT_V31_OUTPUT_ROOT=backend/outputs/v3_1

# Phase 1 local working directory for V3.1 runtime jobs.
CLYPT_PHASE1_WORK_ROOT=backend/outputs/v3_1_phase1_work

# Set to `1` if you want to keep temporary Phase 1 workdirs after a run.
CLYPT_PHASE1_KEEP_WORKDIR=0

# Set to `1` to fail the job when forced alignment returns 0 words on
# non-empty ASR turns (recommended for production). Set to `0` only as a
# temporary debugging bypass.
CLYPT_PHASE1_REQUIRE_FORCED_ALIGNMENT=1

# YAMNet device selection for the Phase 1 worker runtime.
# Keep this as cpu on current droplets (TensorFlow GPU path is unstable here).
CLYPT_PHASE1_YAMNET_DEVICE=cpu

# Visual extraction pipeline (RF-DETR Small + ByteTrack).
# CUDA is required for detection — no silent CPU fallback.
# Backend options:
#   pytorch_cuda_fp16  — PyTorch FP16 on CUDA (default, works everywhere with CUDA)
#   tensorrt_fp16      — native TensorRT FP16 engine (fastest, requires TensorRT install)
CLYPT_PHASE1_VISUAL_BACKEND=pytorch_cuda_fp16
CLYPT_PHASE1_VISUAL_BATCH_SIZE=4
CLYPT_PHASE1_VISUAL_THRESHOLD=0.35
CLYPT_PHASE1_VISUAL_SHAPE=640
CLYPT_PHASE1_VISUAL_TRACKER=bytetrack
CLYPT_PHASE1_VISUAL_TRACKER_BUFFER=30
# Minimum confidence to activate a new ByteTrack track (0.0–1.0). ByteTrack default is 0.7.
CLYPT_PHASE1_VISUAL_TRACKER_MATCH_THRESH=0.7
CLYPT_PHASE1_VISUAL_DECODE=cpu

# TensorRT engine cache directory. Engines are GPU-specific — rebuild when
# switching GPU families.  Only used when BACKEND=tensorrt_fp16.
CLYPT_PHASE1_VISUAL_TRT_ENGINE_DIR=backend/outputs/tensorrt_engines

# VibeVoice ASR (vLLM-only on main).
VIBEVOICE_BACKEND=vllm
VIBEVOICE_VLLM_BASE_URL=http://127.0.0.1:8000
VIBEVOICE_VLLM_MODEL=vibevoice
VIBEVOICE_VLLM_TIMEOUT_S=7200
VIBEVOICE_VLLM_HEALTHCHECK_PATH=/health
VIBEVOICE_VLLM_MAX_RETRIES=1
VIBEVOICE_VLLM_AUDIO_MODE=base64
VIBEVOICE_MAX_NEW_TOKENS=32768
VIBEVOICE_DO_SAMPLE=0
VIBEVOICE_TEMPERATURE=0
VIBEVOICE_TOP_P=1
VIBEVOICE_REPETITION_PENALTY=1
VIBEVOICE_NUM_BEAMS=1
# Context/hotwords (comma-separated in .env; mirrors Gradio-style list).
VIBEVOICE_HOTWORDS_CONTEXT="I, you, he, she, it, we, they, me, him, her, us, them, my, your, his, hers, its, our, their, mine, yours, ours, theirs, this, that, these, those, who, whom, whose, which, what, and, but, or, nor, for, so, yet, after, although, as, because, before, if, since, that, though, unless, until, when, whenever, where, whereas, while, however, therefore, moreover, furthermore, also, additionally, meanwhile, consequently, otherwise, nevertheless, for example, in addition, on the other hand, similarly, likewise, in contrast, thus, hence, indeed, finally, first, second, third"
# vLLM backend — persistent Docker-managed sidecar.
# This is the current production backend on main.
# Run deploy_vllm_service.sh once to bring up the systemd-managed container.
# The generation knobs above (MAX_NEW_TOKENS, TEMPERATURE, etc.) flow through to vLLM.
#
# IMPORTANT: VIBEVOICE_VLLM_MODEL must be "vibevoice" — that is the served-model-name
# registered by start_server.py via --served-model-name vibevoice. Using the HuggingFace
# repo ID (microsoft/VibeVoice-ASR) returns HTTP 404.
#
# IMPORTANT: GOOGLE_CLOUD_PROJECT and GCS_BUCKET are required by load_provider_settings()
# even when running VibeVoice-only (vLLM path). They are not used for ASR but the config
# loader validates them unconditionally. Set them to real values even if Vertex is unused.

# Generation + embedding provider configuration.
# Generation is locked to Gemini Developer API (AI Studio) and requires GEMINI_API_KEY.
# Embeddings remain on Vertex by default for multimodal (URI/video) embedding support.
GENAI_GENERATION_BACKEND=developer
VERTEX_EMBEDDING_BACKEND=vertex
GEMINI_API_KEY=
GOOGLE_CLOUD_PROJECT=clypt-v3
GOOGLE_CLOUD_LOCATION=global
GENAI_GENERATION_LOCATION=global
VERTEX_EMBEDDING_LOCATION=us-central1
GENAI_GENERATION_MODEL=gemini-3-flash-preview
GENAI_FLASH_MODEL=gemini-3-flash-preview
VERTEX_EMBEDDING_MODEL=gemini-embedding-2-preview
# Generation API transient error handling (Developer API path).
GENAI_GENERATION_API_MAX_RETRIES=6
GENAI_GENERATION_API_INITIAL_BACKOFF_S=1.0
GENAI_GENERATION_API_MAX_BACKOFF_S=30.0
GENAI_GENERATION_API_BACKOFF_MULTIPLIER=2.0
GENAI_GENERATION_API_JITTER_RATIO=0.2

# Embedding API transient error handling (Vertex embedding path).
VERTEX_EMBEDDING_API_MAX_RETRIES=6
VERTEX_EMBEDDING_API_INITIAL_BACKOFF_S=1.0
VERTEX_EMBEDDING_API_MAX_BACKOFF_S=30.0
VERTEX_EMBEDDING_API_BACKOFF_MULTIPLIER=2.0
VERTEX_EMBEDDING_API_JITTER_RATIO=0.2

# Storage bucket for source video uploads and Phase 1 runtime persistence.
GCS_BUCKET=clypt-storage-v3

# Phase 2-4 decoupled worker routing (Cloud Tasks -> Cloud Run worker).
# Required when `run_phase14=true` in queue mode (default).
CLYPT_PHASE24_PROJECT=clypt-v3
CLYPT_PHASE24_TASKS_LOCATION=us-central1
CLYPT_PHASE24_TASKS_QUEUE=clypt-phase24
CLYPT_PHASE24_WORKER_URL=
CLYPT_PHASE24_WORKER_SERVICE_ACCOUNT_EMAIL=
CLYPT_PHASE24_WORKER_SERVICE_NAME=clypt-phase24-worker
CLYPT_PHASE24_ENVIRONMENT=dev
CLYPT_PHASE24_QUERY_VERSION=v1
CLYPT_PHASE24_MAX_ATTEMPTS=3
# ffmpeg device for Phase 2 node media clips: auto|gpu|cpu
CLYPT_PHASE24_FFMPEG_DEVICE=gpu
# Bounded worker pool for Phase 2 node clip extraction + upload.
CLYPT_PHASE24_NODE_MEDIA_CONCURRENCY=8

# Gemini generation concurrency inside the Phase 2-4 worker.
CLYPT_GEMINI_MAX_CONCURRENT=8

# Phase 2 batching/tokens.
CLYPT_PHASE2_TARGET_BATCH_COUNT=5
CLYPT_PHASE2_MAX_TURNS_PER_BATCH=25
CLYPT_PHASE2_MERGE_MAX_OUTPUT_TOKENS=32768
CLYPT_PHASE2_BOUNDARY_MAX_OUTPUT_TOKENS=32768

# Phase 3 batching geometry (fewer, larger local-edge batches).
CLYPT_PHASE3_TARGET_BATCH_COUNT=3
CLYPT_PHASE3_MAX_NODES_PER_BATCH=24

# Per-call Flash thinking profile for Phase 2-4.
CLYPT_PHASE2_MERGE_THINKING_LEVEL=low
CLYPT_PHASE2_BOUNDARY_THINKING_LEVEL=minimal
CLYPT_PHASE3_LOCAL_THINKING_LEVEL=minimal
CLYPT_PHASE3_LONG_RANGE_THINKING_LEVEL=low
CLYPT_PHASE4_META_THINKING_LEVEL=low
CLYPT_PHASE4_SUBGRAPH_THINKING_LEVEL=medium
CLYPT_PHASE4_POOL_THINKING_LEVEL=medium

# Spanner graph persistence (run-scoped tables).
CLYPT_SPANNER_PROJECT=clypt-v3
CLYPT_SPANNER_INSTANCE=clypt-spanner-v3
CLYPT_SPANNER_DATABASE=clypt-graph-db-v3

# Shared cache roots (recommended on the droplet/systemd environment).
CLYPT_PHASE1_CACHE_HOME=/opt/clypt-phase1/.cache
XDG_CACHE_HOME=/opt/clypt-phase1/.cache
TORCH_HOME=/opt/clypt-phase1/.cache/torch
HF_HOME=/opt/clypt-phase1/.cache/huggingface
FUNASR_MODEL_SOURCE=hf

# Optional on headless workers: path to GCP service account JSON (GCS signed URLs, Vertex).
# On the DO droplet we use: /opt/clypt-phase1/sa-key.json
# GOOGLE_APPLICATION_CREDENTIALS=/opt/clypt-phase1/sa-key.json
