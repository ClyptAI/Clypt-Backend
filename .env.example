# H200 orchestrator / visual / Phase 2-4 worker env template.
# Copy to `.env.local` if you want to override local defaults.
# For the full code-backed env surface, see `docs/runtime/ENV_REFERENCE.md`.
#
# Topology:
# - This file describes the H200 profile only.
#   * RTX 6000 Ada (sole tenant): VibeVoice vLLM ASR + ffmpeg NVENC
#     node-media prep. See `docs/runtime/known-good-audio-host.env` for
#     that host's template.
#   * H200 (this file): RF-DETR + ByteTrack visual chain, the post-ASR
#     audio chain in-process (NFA, emotion2vec+, YAMNet CPU), SGLang
#     Qwen, Phase 2-4 local SQLite queue + worker.
# - The H200 calls the RTX host over HTTP via RemoteVibeVoiceAsrClient
#   (legacy alias: RemoteAudioChainClient) and RemoteNodeMediaPrepClient.
#   There is NO local VibeVoice or ffmpeg fallback; startup fails fast
#   if the four CLYPT_PHASE1_VIBEVOICE_ASR_SERVICE_* /
#   CLYPT_PHASE24_NODE_MEDIA_PREP_* envs below are unset. The legacy
#   CLYPT_PHASE1_AUDIO_HOST_URL / CLYPT_PHASE1_AUDIO_HOST_TOKEN names are
#   still accepted as deprecated aliases for one release.
# - Do NOT set VIBEVOICE_* envs on the H200. They belong only on the RTX
#   audio host.

# Root directory for Phase 1-4 run artifacts.
CLYPT_V31_OUTPUT_ROOT=backend/outputs/v3_1

# Phase 1 local working directory for V3.1 runtime jobs.
CLYPT_PHASE1_WORK_ROOT=backend/outputs/v3_1_phase1_work

# Set to `1` if you want to keep temporary Phase 1 workdirs after a run.

# Set to `1` to fail the job when forced alignment returns 0 words on
# non-empty ASR turns (recommended for production). Set to `0` only as a
# temporary debugging bypass.
CLYPT_PHASE1_REQUIRE_FORCED_ALIGNMENT=1

# YAMNet device selection for the Phase 1 worker runtime.
# Keep this as cpu on current droplets (TensorFlow GPU path is unstable here).
CLYPT_PHASE1_YAMNET_DEVICE=cpu

# Phase 1 source URL resolution mode.
# test_bank mode resolves incoming source_url to canonical GCS-backed assets
# and hydrates local cache paths on demand.
CLYPT_PHASE1_INPUT_MODE=test_bank
CLYPT_PHASE1_TEST_BANK_PATH=config/test_bank/phase1_canonical_assets.json
CLYPT_PHASE1_TEST_BANK_STRICT=1

# Visual extraction pipeline (RF-DETR Small + ByteTrack).
# CUDA is required for detection — no silent CPU fallback.
# Backend options:
#   cuda_fp16 / pytorch_cuda_fp16 — PyTorch FP16 on CUDA (portable CUDA path)
#   tensorrt_fp16      — native TensorRT FP16 engine (fastest, requires TensorRT install)
# Known-good DO H200 deploys currently pin `tensorrt_fp16`.
CLYPT_PHASE1_VISUAL_BACKEND=pytorch_cuda_fp16
CLYPT_PHASE1_VISUAL_BATCH_SIZE=4
CLYPT_PHASE1_VISUAL_THRESHOLD=0.35
CLYPT_PHASE1_VISUAL_SHAPE=640
CLYPT_PHASE1_VISUAL_TRACKER=bytetrack
CLYPT_PHASE1_VISUAL_TRACKER_BUFFER=30
# Minimum confidence to activate a new ByteTrack track (0.0–1.0). ByteTrack default is 0.7.
CLYPT_PHASE1_VISUAL_TRACKER_MATCH_THRESH=0.7
CLYPT_PHASE1_VISUAL_DECODE=cpu

# TensorRT engine cache directory. Engines are GPU-specific — rebuild when
# switching GPU families.  Only used when BACKEND=tensorrt_fp16.
CLYPT_PHASE1_VISUAL_TRT_ENGINE_DIR=backend/outputs/tensorrt_engines

# Remote VibeVoice ASR service (RTX 6000 Ada, sole tenant). H200 calls this
# over HTTP for POST /tasks/vibevoice-asr (ASR only). NFA, emotion2vec+ and
# YAMNet run in-process on the H200.
# Loading fails fast if _URL or _AUTH_TOKEN is missing.
#
# Compat note: the legacy `CLYPT_PHASE1_AUDIO_HOST_URL` /
# `CLYPT_PHASE1_AUDIO_HOST_TOKEN` names are still accepted as deprecated
# aliases for one release. Prefer the new names below.
CLYPT_PHASE1_VIBEVOICE_ASR_SERVICE_URL=http://<rtx-host>:9100
CLYPT_PHASE1_VIBEVOICE_ASR_SERVICE_AUTH_TOKEN=<shared-bearer>
CLYPT_PHASE1_VIBEVOICE_ASR_SERVICE_TIMEOUT_S=7200
CLYPT_PHASE1_VIBEVOICE_ASR_SERVICE_HEALTHCHECK_PATH=/health

# Remote Phase 2 node-media prep (same RTX 6000 Ada host). H200 calls this
# over HTTP; no local ffmpeg fallback. Loading fails fast if _URL or _TOKEN
# is missing.
CLYPT_PHASE24_NODE_MEDIA_PREP_URL=http://<rtx-host>:9100
CLYPT_PHASE24_NODE_MEDIA_PREP_TOKEN=<shared-bearer>
CLYPT_PHASE24_NODE_MEDIA_PREP_TIMEOUT_S=600
CLYPT_PHASE24_NODE_MEDIA_PREP_MAX_CONCURRENCY=8

# IMPORTANT: VIBEVOICE_* envs do NOT belong on the H200. They are set on
# the RTX 6000 Ada audio host only. See docs/runtime/known-good-audio-host.env.
#
# IMPORTANT: GOOGLE_CLOUD_PROJECT and GCS_BUCKET are required by
# load_provider_settings() even if Vertex is unused.

# Generation + embedding provider configuration.
# Generation defaults to a local OpenAI-compatible server (vLLM Qwen). Set
# GENAI_GENERATION_BACKEND=developer to use Gemini Developer API (AI Studio) with GEMINI_API_KEY.
# Embeddings remain on Vertex by default for multimodal (URI/video) embedding support.
GENAI_GENERATION_BACKEND=local_openai
VERTEX_EMBEDDING_BACKEND=vertex
GEMINI_API_KEY=

# Local OpenAI-compatible LLM (Qwen / vLLM) — used when GENAI_GENERATION_BACKEND=local_openai.
CLYPT_LOCAL_LLM_BASE_URL=http://127.0.0.1:8001/v1
CLYPT_LOCAL_LLM_MODEL=Qwen/Qwen3.6-35B-A3B
CLYPT_LOCAL_LLM_TIMEOUT_S=600
CLYPT_LOCAL_LLM_MAX_RETRIES=6
CLYPT_LOCAL_LLM_INITIAL_BACKOFF_S=1.0
CLYPT_LOCAL_LLM_MAX_BACKOFF_S=30.0
CLYPT_LOCAL_LLM_BACKOFF_MULTIPLIER=2.0
CLYPT_LOCAL_LLM_JITTER_RATIO=0.2
CLYPT_LOCAL_LLM_TEMPERATURE=0.0
CLYPT_LOCAL_LLM_TOP_P=1.0
CLYPT_LOCAL_LLM_TOP_K=40
CLYPT_LOCAL_LLM_MIN_P=0.0
CLYPT_LOCAL_LLM_PRESENCE_PENALTY=0.0
CLYPT_LOCAL_LLM_REPETITION_PENALTY=1.0
GOOGLE_CLOUD_PROJECT=clypt-v3
GOOGLE_CLOUD_LOCATION=global
GENAI_GENERATION_LOCATION=global
VERTEX_EMBEDDING_LOCATION=us-central1
GENAI_GENERATION_MODEL=Qwen/Qwen3.6-35B-A3B
GENAI_FLASH_MODEL=Qwen/Qwen3.6-35B-A3B
VERTEX_EMBEDDING_MODEL=gemini-embedding-2-preview
# Generation API transient error handling (Developer API path).
GENAI_GENERATION_API_MAX_RETRIES=6
GENAI_GENERATION_API_INITIAL_BACKOFF_S=1.0
GENAI_GENERATION_API_MAX_BACKOFF_S=30.0
GENAI_GENERATION_API_BACKOFF_MULTIPLIER=2.0
GENAI_GENERATION_API_JITTER_RATIO=0.2

# Embedding API transient error handling (Vertex embedding path).
VERTEX_EMBEDDING_API_MAX_RETRIES=6
VERTEX_EMBEDDING_API_INITIAL_BACKOFF_S=1.0
VERTEX_EMBEDDING_API_MAX_BACKOFF_S=30.0
VERTEX_EMBEDDING_API_BACKOFF_MULTIPLIER=2.0
VERTEX_EMBEDDING_API_JITTER_RATIO=0.2

# Storage bucket for source video uploads and Phase 1 runtime persistence.
GCS_BUCKET=clypt-storage-v3

# Phase 2-4 queue backend for local Phase 1 (`run_phase14`): durable SQLite (default).
# Phase1 `build_default_phase1_job_runner` requires `local_sqlite`.
CLYPT_PHASE24_QUEUE_BACKEND=local_sqlite
CLYPT_PHASE24_LOCAL_QUEUE_PATH=backend/outputs/phase24_local_queue.sqlite
CLYPT_PHASE24_LOCAL_POLL_INTERVAL_MS=500
CLYPT_PHASE24_LOCAL_LEASE_TIMEOUT_S=1800
CLYPT_PHASE24_LOCAL_MAX_INFLIGHT=1
CLYPT_PHASE24_LOCAL_MAX_REQUESTS_PER_WORKER=0
CLYPT_PHASE24_LOCAL_RECLAIM_EXPIRED_LEASES=0
CLYPT_PHASE24_LOCAL_FAIL_FAST_ON_STALE_RUNNING=1
# Optional: override worker identity in `python -m backend.runtime.run_phase24_local_worker`
# CLYPT_PHASE24_LOCAL_WORKER_ID=phase24-local-worker

# SGLang runtime tuning surface for Qwen3.6 is driven by SG_* knobs in the
# deploy script (scripts/do_phase1_visual/deploy_sglang_qwen_service.sh) and
# the clypt-sglang-qwen systemd unit on the H200, not via these Python-facing
# envs. The previous CLYPT_VLLM_* surface has been removed.

# Phase 2-4 worker identity and admission knobs (local SQLite queue path; see
# CLYPT_PHASE24_QUEUE_BACKEND above).
CLYPT_PHASE24_WORKER_SERVICE_NAME=clypt-phase24-worker
CLYPT_PHASE24_ENVIRONMENT=dev
CLYPT_PHASE24_QUERY_VERSION=v1
CLYPT_PHASE24_MAX_ATTEMPTS=3
CLYPT_PHASE24_FAILFAST_PREEMPTION_THRESHOLD=0
CLYPT_PHASE24_FAILFAST_P95_LATENCY_MS=0
# Optional JSON file with { "preemption_count": <int> } read by local worker admission check.
# CLYPT_PHASE24_ADMISSION_METRICS_PATH=/tmp/clypt_admission_metrics.json
CLYPT_PHASE24_BLOCK_ON_PHASE1_ACTIVE=0
# NOTE: ffmpeg hardware selection (`CLYPT_PHASE24_FFMPEG_DEVICE`) is a
# RTX-host-side env now. On the H200 it has no effect because node-media
# prep is always delegated remotely to the RTX audio host.

# Phase 2 batching/tokens/concurrency.
# Concurrency values are MAX in-flight LLM request caps per stage, validated
# against Qwen3.6-35B-A3B on H200 (2026-04-16 bench). Smaller videos stay well
# below these caps; only large videos scale up to them.
CLYPT_PHASE2_TARGET_BATCH_COUNT=5
CLYPT_PHASE2_MAX_TURNS_PER_BATCH=25
CLYPT_PHASE2_MERGE_MAX_CONCURRENT=16
CLYPT_PHASE2_BOUNDARY_MAX_CONCURRENT=16
CLYPT_PHASE2_MERGE_MAX_OUTPUT_TOKENS=8192
CLYPT_PHASE2_BOUNDARY_MAX_OUTPUT_TOKENS=8192

# Signals concurrency.
CLYPT_SIGNAL_MAX_CONCURRENT=8

# Phase 3 batching geometry (fewer, larger local-edge batches).
CLYPT_PHASE3_TARGET_BATCH_COUNT=3
CLYPT_PHASE3_MAX_NODES_PER_BATCH=24
CLYPT_PHASE3_LOCAL_MAX_CONCURRENT=24
CLYPT_PHASE3_LONG_RANGE_TOP_K=2
CLYPT_PHASE3_LONG_RANGE_PAIRS_PER_SHARD=24
CLYPT_PHASE3_LONG_RANGE_MAX_CONCURRENT=24

# Phase 4 concurrency.
CLYPT_PHASE4_SUBGRAPH_MAX_CONCURRENT=16

CLYPT_PHASE3_LOCAL_MAX_OUTPUT_TOKENS=4096
CLYPT_PHASE3_LONG_RANGE_MAX_OUTPUT_TOKENS=4096
CLYPT_PHASE4_META_MAX_OUTPUT_TOKENS=4096
CLYPT_PHASE4_SUBGRAPH_MAX_OUTPUT_TOKENS=4096
CLYPT_PHASE4_POOL_MAX_OUTPUT_TOKENS=4096
CLYPT_PHASE4_SUBGRAPH_OVERLAP_DEDUPE_THRESHOLD=0.70

# Spanner graph persistence (run-scoped tables).
CLYPT_SPANNER_PROJECT=clypt-v3
CLYPT_SPANNER_INSTANCE=clypt-spanner-v3
CLYPT_SPANNER_DATABASE=clypt-graph-db-v3

# Shared cache roots (recommended on the droplet/systemd environment).
CLYPT_PHASE1_CACHE_HOME=/opt/clypt-phase1/.cache
XDG_CACHE_HOME=/opt/clypt-phase1/.cache
TORCH_HOME=/opt/clypt-phase1/.cache/torch
HF_HOME=/opt/clypt-phase1/.cache/huggingface
FUNASR_MODEL_SOURCE=hf

# Optional on headless workers: path to GCP service account JSON (GCS signed URLs, Vertex).
# On the DO droplet we use: /opt/clypt-phase1/sa-key.json
# GOOGLE_APPLICATION_CREDENTIALS=/opt/clypt-phase1/sa-key.json
