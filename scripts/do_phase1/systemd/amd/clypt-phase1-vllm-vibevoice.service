[Unit]
Description=Clypt Phase 1 VibeVoice vLLM ROCm Sidecar
After=docker.service network-online.target
Requires=docker.service

[Service]
Type=simple
WorkingDirectory=/opt/clypt-phase1/repo
EnvironmentFile=/etc/clypt-phase1/phase1.env
EnvironmentFile=-/etc/clypt-phase1/vibevoice-model.env
Environment=CLYPT_ACCELERATOR=rocm
Environment=HF_HUB_OFFLINE=1
ExecStartPre=-/usr/bin/docker stop clypt-phase1-vllm-vibevoice
ExecStartPre=-/usr/bin/docker rm clypt-phase1-vllm-vibevoice
ExecStart=/usr/local/bin/clypt-phase1-run-vllm-vibevoice-rocm
ExecStop=/usr/bin/docker stop clypt-phase1-vllm-vibevoice
Restart=always
RestartSec=10
TimeoutStartSec=900

[Install]
WantedBy=multi-user.target
