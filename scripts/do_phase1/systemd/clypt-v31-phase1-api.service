[Unit]
Description=Clypt V3.1 Phase 1 API
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/clypt-phase1/repo
EnvironmentFile=/etc/clypt-phase1/v3_1_phase1.env
ExecStart=/opt/clypt-phase1/repo/.venv/bin/python -m backend.runtime.run_phase1_service --host 0.0.0.0 --port 8080
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
