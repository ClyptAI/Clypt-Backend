[Unit]
Description=Clypt Phase 1 VibeVoice Service
After=network.target clypt-phase1-vllm-vibevoice.service
Requires=clypt-phase1-vllm-vibevoice.service

[Service]
Type=simple
WorkingDirectory=/opt/clypt-phase1/repo
EnvironmentFile=/etc/clypt-phase1/phase1.env
EnvironmentFile=/etc/clypt/clypt-phase1-runtime.env
ExecStart=/opt/clypt-phase1/venvs/phase1/bin/python -m backend.runtime.run_phase1_vibevoice_service --host 127.0.0.1 --port 9100
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
