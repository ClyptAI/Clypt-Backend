[Unit]
Description=Clypt Phase 1 API
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/clypt-phase1/repo
EnvironmentFile=/etc/clypt-phase1/phase1.env
EnvironmentFile=/etc/clypt/clypt-phase1-runtime.env
ExecStart=/opt/clypt-phase1/venvs/phase1/bin/python -m backend.runtime.run_phase1_service --host 0.0.0.0 --port 8080 --db-path /var/lib/clypt/phase1/jobs.db --logs-root /var/log/clypt/phase1
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
