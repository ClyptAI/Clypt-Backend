# DigitalOcean Phase 1 service runtime
DO_REGION=atl1
DO_PHASE1_WORKER_ID=clypt-phase1-gpu-1

# Durable local state on the droplet
DO_PHASE1_STATE_ROOT=/var/lib/clypt/do_phase1_service
DO_PHASE1_DB_PATH=/var/lib/clypt/do_phase1_service/jobs.db
DO_PHASE1_OUTPUT_ROOT=/var/lib/clypt/do_phase1_service/workdir
DO_PHASE1_LOG_ROOT=/var/lib/clypt/do_phase1_service/workdir/logs
DO_PHASE1_HOST_LOCK_PATH=/var/lib/clypt/do_phase1_service/extract.lock
DO_PHASE1_RUNNING_STALE_AFTER_SECONDS=1800
DO_PHASE1_HEARTBEAT_INTERVAL_SECONDS=30
DO_PHASE1_LOOP_ERROR_BACKOFF_SECONDS=2
DO_PHASE1_LOG_LEVEL=INFO
DO_PHASE1_WORKER_CONCURRENCY=1
DO_PHASE1_GPU_SLOTS=1
# For current podcast evals on a single H200, we typically bump to:
# DO_PHASE1_WORKER_CONCURRENCY=3
# DO_PHASE1_GPU_SLOTS=1

# API/runtime
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8080

# GCP / GCS credentials for artifact persistence
GOOGLE_APPLICATION_CREDENTIALS=/etc/clypt-phase1/gcp-sa.json
GCS_BUCKET=clypt-storage-v3
GOOGLE_CLOUD_PROJECT=

# Local pipeline client should point here
# DO_PHASE1_BASE_URL=http://YOUR_DROPLET_IP:8080

# Phase1 v3 policy defaults
CLYPT_SPEAKER_BINDING_MODE=lrasd
# v3 default: no silent whole-job heuristic when LR-ASD yields None; set 1 to opt in.
CLYPT_SPEAKER_BINDING_HEURISTIC_FALLBACK=0
CLYPT_TRACKING_MODE=direct
CLYPT_TRACKER_BACKEND=bytetrack
CLYPT_TRACK_CHUNK_WORKERS=1
CLYPT_SPEAKER_BINDING_PROXY_ENABLE=1
CLYPT_ANALYSIS_PROXY_MAX_LONG_EDGE=1280
YOLO_WEIGHTS_PATH=yolo26m-seg.pt
CLYPT_YOLO_IMGSZ=1080
# LR-ASD runtime profile: auto maps H200/H100/A100 to tuned defaults.
# Override with explicit CLYPT_LRASD_BATCH_SIZE / CLYPT_LRASD_MAX_INFLIGHT when needed.
CLYPT_LRASD_PROFILE=auto
CLYPT_LRASD_PIPELINE_OVERLAP=1
# CLYPT_LRASD_BATCH_SIZE=48     # optional H200 override
# CLYPT_LRASD_MAX_INFLIGHT=4    # optional H200 override
CLYPT_FACE_PIPELINE_START_FRAME=0
CLYPT_FACE_DETECTOR_INPUT_LONG_EDGE=1280
CLYPT_FULLFRAME_FACE_MIN_SIZE=14
CLYPT_FACE_PIPELINE_GPU=1
# Medium-gap face observation propagation (tracklet-assisted interpolation within face tracks).
# Gap range [MIN, MAX] frames; confidence decays exponentially; propagation stops below MIN_CONF.
# CLYPT_FACE_OBS_MEDIUM_GAP_MIN=3
# CLYPT_FACE_OBS_MEDIUM_GAP_MAX=30
# CLYPT_FACE_OBS_MEDIUM_GAP_DECAY=0.88
# CLYPT_FACE_OBS_MEDIUM_GAP_MIN_CONF=0.10
# Cross-tracklet identity propagation quality gate (combined gap+signature score ceiling).
# CLYPT_FACE_TRACK_PROPAGATE_MAX_COMBINED_SCORE=1.50

# Pyannote diarization (disabled by default)
CLYPT_AUDIO_DIARIZATION_ENABLE=0
CLYPT_AUDIO_DIARIZATION_MODEL=pyannote/speaker-diarization-3.1
CLYPT_AUDIO_DIARIZATION_MIN_SEGMENT_MS=400
# Set a Hugging Face token with access to the pyannote model when diarization is enabled.
# HF_TOKEN is preferred; HUGGINGFACE_HUB_TOKEN is also commonly recognized.
# community-1 is deferred until we upgrade the pyannote/torch stack.
HF_TOKEN=

# Gemini overlap-follow (camera-policy adjudication during overlapping speech windows).
# Disabled by default; enable once overlap pipeline is validated end-to-end.
CLYPT_OVERLAP_FOLLOW_ENABLE=0
# CLYPT_OVERLAP_FOLLOW_MODEL=gemini-2.0-flash
# Direct Gemini API key (set one of GEMINI_API_KEY or GOOGLE_API_KEY, or use Vertex AI below).
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
# Vertex AI alternative: set GOOGLE_GENAI_USE_VERTEXAI=1 and fill project/location.
# GOOGLE_GENAI_USE_VERTEXAI=0
# GOOGLE_CLOUD_LOCATION=us-central1
