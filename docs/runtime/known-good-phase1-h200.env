# Phase 1 H200 default production baseline.
#
# Hosts:
#   * Phase 1 runner/API/worker
#   * persistent local VibeVoice service on :9100
#   * persistent local visual service on :9200
#   * co-located VibeVoice vLLM sidecar on :8000
#   * in-process NFA + emotion2vec+ + YAMNet

CLYPT_V31_OUTPUT_ROOT=backend/outputs/v3_1
CLYPT_PHASE1_WORK_ROOT=backend/outputs/v3_1_phase1_work
CLYPT_PHASE1_REQUIRE_FORCED_ALIGNMENT=1
CLYPT_PHASE1_INPUT_MODE=test_bank
CLYPT_PHASE1_TEST_BANK_PATH=/opt/clypt-phase1/repo/config/test_bank/phase1_canonical_assets.json
CLYPT_PHASE1_TEST_BANK_STRICT=1

CLYPT_PHASE1_VISUAL_MODEL=nano
CLYPT_PHASE1_VISUAL_BACKEND=tensorrt_fp16
CLYPT_PHASE1_VISUAL_BATCH_SIZE=16
CLYPT_PHASE1_VISUAL_THRESHOLD=0.35
CLYPT_PHASE1_VISUAL_SHAPE=640
CLYPT_PHASE1_VISUAL_TRACKER=bytetrack
CLYPT_PHASE1_VISUAL_TRACKER_BUFFER=30
CLYPT_PHASE1_VISUAL_TRACKER_MATCH_THRESH=0.7
CLYPT_PHASE1_VISUAL_DECODE=gpu
CLYPT_PHASE1_VISUAL_TRT_ENGINE_DIR=backend/outputs/tensorrt_engines

CLYPT_PHASE1_YAMNET_DEVICE=cpu
FUNASR_MODEL_SOURCE=hf

GOOGLE_CLOUD_PROJECT=clypt-v3
GOOGLE_CLOUD_LOCATION=global
GCS_BUCKET=clypt-storage-v3
GOOGLE_APPLICATION_CREDENTIALS=/opt/clypt-phase1/sa-key.json
CLYPT_YOUTUBE_DATA_API_KEY=replace-me

CLYPT_PHASE1_VIBEVOICE_ASR_SERVICE_URL=http://127.0.0.1:9100
CLYPT_PHASE1_VIBEVOICE_ASR_SERVICE_AUTH_TOKEN=replace-me
CLYPT_PHASE1_VIBEVOICE_ASR_SERVICE_TIMEOUT_S=7200
CLYPT_PHASE1_VIBEVOICE_ASR_SERVICE_HEALTHCHECK_PATH=/health

CLYPT_PHASE1_VISUAL_SERVICE_URL=http://127.0.0.1:9200
CLYPT_PHASE1_VISUAL_SERVICE_AUTH_TOKEN=replace-me
CLYPT_PHASE1_VISUAL_SERVICE_TIMEOUT_S=3600
CLYPT_PHASE1_VISUAL_SERVICE_HEALTHCHECK_PATH=/health

# Current cross-team working topology uses the public Phase26 dispatch endpoint.
CLYPT_PHASE24_DISPATCH_URL=http://107.170.33.122:9300
CLYPT_PHASE24_DISPATCH_AUTH_TOKEN=replace-me
CLYPT_PHASE24_DISPATCH_TIMEOUT_S=30

CLYPT_PHASE24_QUERY_VERSION=v1

VIBEVOICE_BACKEND=vllm
VIBEVOICE_VLLM_BASE_URL=http://127.0.0.1:8000
VIBEVOICE_VLLM_MODEL=vibevoice
VIBEVOICE_MAX_NEW_TOKENS=32000
VIBEVOICE_VLLM_GPU_MEMORY_UTILIZATION=0.60
VIBEVOICE_VLLM_MAX_NUM_SEQS=4
VIBEVOICE_VLLM_DTYPE=bfloat16
VIBEVOICE_LONGFORM_ENABLED=1
VIBEVOICE_LONGFORM_SINGLE_PASS_MAX_MINUTES=40
VIBEVOICE_LONGFORM_TWO_SHARD_MAX_MINUTES=80
VIBEVOICE_LONGFORM_FOUR_SHARD_MAX_MINUTES=160
VIBEVOICE_LONGFORM_MAX_SHARDS=4
VIBEVOICE_LONGFORM_SPEAKER_MATCH_THRESHOLD=0.85
VIBEVOICE_LONGFORM_REP_CLIP_MIN_SECONDS=15
VIBEVOICE_LONGFORM_REP_CLIP_MAX_SECONDS=30
VIBEVOICE_LONGFORM_VERIFIER_BACKEND=ecapa_tdnn
VIBEVOICE_LONGFORM_VERIFIER_DEVICE=cpu
VIBEVOICE_LONGFORM_VERIFIER_MODEL_ID=speechbrain/spkrec-ecapa-voxceleb

CLYPT_SPANNER_INSTANCE=clypt-spanner-v3
CLYPT_SPANNER_DATABASE=clypt-graph-db-v3

CLYPT_PHASE1_CACHE_HOME=/opt/clypt-phase1/.cache
XDG_CACHE_HOME=/opt/clypt-phase1/.cache
TORCH_HOME=/opt/clypt-phase1/.cache/torch
HF_HOME=/opt/clypt-phase1/.cache/huggingface
