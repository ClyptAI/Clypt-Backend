# Backup overlay for running the Phase 1 host on an H100 instead of an H200.
# Apply on top of known-good-phase1-h200.env.
#
# Only memory-sensitive knobs belong here. Do not change RF-DETR thresholds,
# tracker settings, or other semantic behavior in this overlay.

VIBEVOICE_VLLM_GPU_MEMORY_UTILIZATION=0.74
VIBEVOICE_VLLM_MAX_NUM_SEQS=2
