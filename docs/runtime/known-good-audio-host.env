# Known-good env file for the RTX 6000 Ada VibeVoice ASR + node-media-prep
# host.
#
# Deploy this to /etc/clypt-audio-host/audio_host.env on the RTX droplet.
#
# Rule of thumb for this host (post-2026-04-17 revert):
#   * Sole-tenant VibeVoice + ffmpeg. VibeVoice vLLM runs with
#     default/sole-tenant flags — no more --max-num-seqs 1 /
#     --max-model-len 32768 / --gpu-memory-utilization 0.60 /
#     --enforce-eager / PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True.
#     Those were co-tenancy workarounds for when NFA shared the GPU.
#   * It serves exactly two POST endpoints plus /health:
#       POST /tasks/vibevoice-asr     (VibeVoice ASR only)
#       POST /tasks/node-media-prep   (ffmpeg NVENC/NVDEC clip extraction)
#     NFA, emotion2vec+, and YAMNet do NOT run here anymore — they moved
#     back to the H200 in-process.
#   * Everything below must be present. scripts/do_phase1_audio/deploy_audio_service.sh
#     fails fast when any of the required vars below are unset.

# --- FastAPI host ---------------------------------------------------------
# Bind to 0.0.0.0 only if the droplet is inside a private DO VPC. Otherwise
# front this with a firewall allowlist of the H200's outbound IP.
CLYPT_PHASE1_AUDIO_HOST_BIND=0.0.0.0
CLYPT_PHASE1_AUDIO_HOST_PORT=9100

# Shared bearer token. Must match the H200's
# CLYPT_PHASE1_VIBEVOICE_ASR_SERVICE_AUTH_TOKEN and
# CLYPT_PHASE24_NODE_MEDIA_PREP_TOKEN (same value reused for both).
CLYPT_PHASE1_VIBEVOICE_ASR_SERVICE_AUTH_TOKEN=replace-me-with-a-real-token
# Compat alias (deprecated, accepted for one release):
#   CLYPT_PHASE1_AUDIO_HOST_TOKEN
# Do not use in new deployments.

# Temp workspace for per-request GCS downloads + ffmpeg clips.
CLYPT_PHASE1_AUDIO_HOST_SCRATCH_ROOT=/opt/clypt-audio-host/scratch

# --- VibeVoice vLLM (runs in-process with this service, sole tenant) ------
VIBEVOICE_BACKEND=vllm
VIBEVOICE_VLLM_BASE_URL=http://127.0.0.1:8000
VIBEVOICE_VLLM_MODEL=vibevoice
VIBEVOICE_HOTWORDS_CONTEXT="clypt, vibevoice, rf-detr, sglang, qwen"

# --- GCP / storage --------------------------------------------------------
GOOGLE_CLOUD_PROJECT=replace-me
GCS_BUCKET=replace-me
GOOGLE_APPLICATION_CREDENTIALS=/opt/clypt-audio-host/sa-key.json

# --- Caches (match the systemd unit Environment= block) -------------------
HF_HOME=/opt/clypt-audio-host/.cache/huggingface
TORCH_HOME=/opt/clypt-audio-host/.cache/torch
CLYPT_PHASE1_CACHE_HOME=/opt/clypt-audio-host/.cache
XDG_CACHE_HOME=/opt/clypt-audio-host/.cache

# Note: NFA-/FunASR-/YAMNet-related envs (FUNASR_MODEL_SOURCE,
# CLYPT_PHASE1_YAMNET_DEVICE, etc.) are NOT consumed on this host anymore.
# They live on the H200 alongside the in-process audio post chain.
