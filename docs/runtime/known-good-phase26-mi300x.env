# Phase26 MI300X production baseline for AMD-refactor.
#
# This replaces the Phase26 H200/SGLang env on this branch. Modal L40S remains
# the external node-media-prep/render path.

GOOGLE_CLOUD_PROJECT=clypt-v3
GOOGLE_CLOUD_LOCATION=global
GENAI_GENERATION_LOCATION=global
VERTEX_EMBEDDING_LOCATION=us-central1
GCS_BUCKET=clypt-storage-v3
GOOGLE_APPLICATION_CREDENTIALS=/opt/clypt-phase26/sa-key.json

GENAI_GENERATION_BACKEND=local_openai
VERTEX_EMBEDDING_BACKEND=vertex
GENAI_GENERATION_MODEL=Qwen/Qwen3.6-35B-A3B
GENAI_FLASH_MODEL=Qwen/Qwen3.6-35B-A3B
VERTEX_EMBEDDING_MODEL=gemini-embedding-2-preview

CLYPT_LOCAL_LLM_BASE_URL=http://127.0.0.1:8001/v1
CLYPT_LOCAL_LLM_MODEL=Qwen/Qwen3.6-35B-A3B
CLYPT_LOCAL_LLM_TIMEOUT_S=600
CLYPT_LOCAL_LLM_MAX_RETRIES=6

SG_DOCKER_IMAGE=lmsysorg/sglang:v0.5.10-rocm720-mi30x
SG_MODEL=Qwen/Qwen3.6-35B-A3B
SG_MODEL_REVISION=main
SG_SERVED_MODEL_NAME=Qwen/Qwen3.6-35B-A3B
SG_LAUNCH_PROFILE=final
SG_ACCEPTANCE_PROFILES=minimal strict_json fp8_kv scheduler_cache speculative
SG_SCHEDULE_POLICY=lpm
SG_CHUNKED_PREFILL_SIZE=8192
SG_MEM_FRACTION_STATIC=0.78
SG_CONTEXT_LENGTH=65536
SG_KV_CACHE_DTYPE=fp8_e4m3
SG_GRAMMAR_BACKEND=xgrammar
SG_REASONING_PARSER=qwen3
SG_ATTENTION_BACKEND=triton
SG_MAMBA_SCHEDULER_STRATEGY=extra_buffer
SG_SPECULATIVE_ALGORITHM=NEXTN
SG_SPECULATIVE_NUM_STEPS=3
SG_SPECULATIVE_EAGLE_TOPK=1
SG_SPECULATIVE_NUM_DRAFT_TOKENS=4
SG_ENABLE_SPEC_V2=1
HF_HUB_OFFLINE=1

CLYPT_PHASE24_NODE_MEDIA_PREP_URL=https://testifytestprep--clypt-node-media-prep-node-media-prep.modal.run/tasks/node-media-prep
CLYPT_PHASE24_NODE_MEDIA_PREP_TOKEN=replace-me
CLYPT_PHASE24_NODE_MEDIA_PREP_TIMEOUT_S=1800
CLYPT_PHASE24_NODE_MEDIA_PREP_MAX_CONCURRENCY=12
CLYPT_PHASE24_NODE_MEDIA_PREP_MAX_INFLIGHT_BATCHES=3
CLYPT_PHASE24_NODE_MEDIA_BATCH_GAP_MS=2000
CLYPT_PHASE24_NODE_MEDIA_BATCH_MAX_NODES=8
CLYPT_PHASE24_NODE_MEDIA_BATCH_MAX_SPAN_MS=120000
CLYPT_PHASE24_NODE_MEDIA_BATCH_PAD_MS=2000
CLYPT_PHASE24_NODE_MEDIA_BATCH_COARSE_SEEK_PAD_MS=10000
CLYPT_PHASE4_META_MAX_OUTPUT_TOKENS=4096
CLYPT_PHASE4_POOL_MAX_OUTPUT_TOKENS=8192

# Enable when the remote Phase 6 render/export surface is deployed on Modal L40S.
# CLYPT_PHASE24_PHASE6_RENDER_URL=https://<modal-render-surface>/tasks/render-video
# CLYPT_PHASE24_PHASE6_RENDER_TOKEN=replace-me
# CLYPT_PHASE24_PHASE6_RENDER_TIMEOUT_S=3600

CLYPT_PHASE24_DISPATCH_AUTH_TOKEN=replace-me
CLYPT_PHASE24_QUERY_VERSION=v1
CLYPT_PHASE24_QUEUE_BACKEND=local_sqlite
CLYPT_PHASE24_LOCAL_QUEUE_PATH=/opt/clypt-phase26/repo/backend/outputs/phase24_local_queue.sqlite
CLYPT_PHASE24_LOCAL_POLL_INTERVAL_MS=500
CLYPT_PHASE24_LOCAL_LEASE_TIMEOUT_S=1800
CLYPT_PHASE24_LOCAL_MAX_INFLIGHT=1
CLYPT_PHASE24_LOCAL_MAX_REQUESTS_PER_WORKER=0
CLYPT_PHASE24_LOCAL_WORKER_ID=phase26-worker-1
CLYPT_PHASE24_LOCAL_RECLAIM_EXPIRED_LEASES=0
CLYPT_PHASE24_LOCAL_FAIL_FAST_ON_STALE_RUNNING=1

CLYPT_PHASE24_WORKER_SERVICE_NAME=clypt-phase26-worker
CLYPT_PHASE24_ENVIRONMENT=prod
CLYPT_PHASE24_MAX_ATTEMPTS=3
CLYPT_DEBUG_SNAPSHOTS=0

CLYPT_SIGNAL_LLM_MODEL_1=Qwen/Qwen3.6-35B-A3B
CLYPT_SIGNAL_LLM_MODEL_2=Qwen/Qwen3.6-35B-A3B
CLYPT_SIGNAL_LLM_MODEL_3=Qwen/Qwen3.6-35B-A3B
CLYPT_SIGNAL_LLM_MODEL_5=Qwen/Qwen3.6-35B-A3B
CLYPT_SIGNAL_LLM_MODEL_9=Qwen/Qwen3.6-35B-A3B
CLYPT_SIGNAL_LLM_MODEL_10=Qwen/Qwen3.6-35B-A3B
CLYPT_SIGNAL_LLM_MODEL_11=Qwen/Qwen3.6-35B-A3B

CLYPT_SPANNER_INSTANCE=clypt-spanner-v3
CLYPT_SPANNER_DATABASE=clypt-graph-db-v3

CLYPT_PHASE1_CACHE_HOME=/opt/clypt-phase26/.cache
XDG_CACHE_HOME=/opt/clypt-phase26/.cache
TORCH_HOME=/opt/clypt-phase26/.cache/torch
HF_HOME=/opt/clypt-phase26/.cache/huggingface
PYTORCH_KERNEL_CACHE_PATH=/opt/clypt-phase26/.cache/torch/kernels
HIP_VISIBLE_DEVICES=0
ROCR_VISIBLE_DEVICES=0
