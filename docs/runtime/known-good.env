# Known-good H200 host env baseline (visual chain + Phase 2-4 worker + SGLang).
#
# Deploy this to /etc/clypt-phase1/v3_1_phase1.env on the H200 droplet.
# For the audio host (RTX 6000 Ada), use docs/runtime/known-good-audio-host.env.
# For the exhaustive code-backed env inventory, see docs/runtime/ENV_REFERENCE.md.
#
# Topology:
#   * H200  -> this file. RF-DETR + ByteTrack, Phase 1 API/worker, Phase 2-4 local
#              queue + worker, SGLang Qwen3.6-35B-A3B on :8001.
#   * RTX6000ADA -> docs/runtime/known-good-audio-host.env. VibeVoice vLLM ASR +
#                   NFA + emotion2vec+ + YAMNet + ffmpeg NVENC node-media prep.
#
# The H200 does NOT run VibeVoice / NFA / emotion2vec+ / YAMNet / ffmpeg NVENC.
# Leaving VIBEVOICE_BACKEND or VIBEVOICE_VLLM_BASE_URL set on this host is a
# deployment bug: scripts/do_phase1_visual/deploy_visual_service.sh will abort
# if it detects those.

# -----------------------------------------------------------------------------
# Core Phase 1 runtime
# -----------------------------------------------------------------------------
CLYPT_V31_OUTPUT_ROOT=backend/outputs/v3_1
CLYPT_PHASE1_WORK_ROOT=backend/outputs/v3_1_phase1_work
CLYPT_PHASE1_KEEP_WORKDIR=0
CLYPT_PHASE1_REQUIRE_FORCED_ALIGNMENT=1
CLYPT_PHASE1_INPUT_MODE=test_bank
CLYPT_PHASE1_TEST_BANK_PATH=/opt/clypt-phase1/repo/config/test_bank/phase1_canonical_assets.json
CLYPT_PHASE1_TEST_BANK_STRICT=1

# -----------------------------------------------------------------------------
# Visual pipeline (H200-only)
# -----------------------------------------------------------------------------
CLYPT_PHASE1_VISUAL_BACKEND=tensorrt_fp16
CLYPT_PHASE1_VISUAL_BATCH_SIZE=16
CLYPT_PHASE1_VISUAL_THRESHOLD=0.35
CLYPT_PHASE1_VISUAL_SHAPE=640
CLYPT_PHASE1_VISUAL_TRACKER=bytetrack
CLYPT_PHASE1_VISUAL_TRACKER_BUFFER=30
CLYPT_PHASE1_VISUAL_TRACKER_MATCH_THRESH=0.7
CLYPT_PHASE1_VISUAL_DECODE=gpu
CLYPT_PHASE1_VISUAL_TRT_ENGINE_DIR=backend/outputs/tensorrt_engines

# -----------------------------------------------------------------------------
# Remote Phase 1 audio host (RTX 6000 Ada). REQUIRED — no local fallback.
# -----------------------------------------------------------------------------
CLYPT_PHASE1_AUDIO_HOST_URL=http://<rtx6000ada-private-ip>:9100
CLYPT_PHASE1_AUDIO_HOST_TOKEN=replace-me-with-the-shared-audio-host-token
CLYPT_PHASE1_AUDIO_HOST_TIMEOUT_S=7200
CLYPT_PHASE1_AUDIO_HOST_HEALTHCHECK_PATH=/health

# -----------------------------------------------------------------------------
# Remote node-media prep (RTX 6000 Ada — uses the same audio host droplet).
# REQUIRED — H200 NVENC is not usable so there is no local fallback.
# -----------------------------------------------------------------------------
CLYPT_PHASE24_NODE_MEDIA_PREP_URL=http://<rtx6000ada-private-ip>:9100
CLYPT_PHASE24_NODE_MEDIA_PREP_TOKEN=replace-me-with-the-shared-audio-host-token
CLYPT_PHASE24_NODE_MEDIA_PREP_TIMEOUT_S=1800
CLYPT_PHASE24_NODE_MEDIA_PREP_MAX_CONCURRENCY=8

# -----------------------------------------------------------------------------
# GCP / storage
# -----------------------------------------------------------------------------
GOOGLE_CLOUD_PROJECT=clypt-v3
GOOGLE_CLOUD_LOCATION=global
GENAI_GENERATION_LOCATION=global
VERTEX_EMBEDDING_LOCATION=us-central1
GCS_BUCKET=clypt-storage-v3
GOOGLE_APPLICATION_CREDENTIALS=/opt/clypt-phase1/sa-key.json

# -----------------------------------------------------------------------------
# Generation + embeddings (SGLang Qwen lives on this H200)
# -----------------------------------------------------------------------------
GENAI_GENERATION_BACKEND=local_openai
VERTEX_EMBEDDING_BACKEND=vertex
GENAI_GENERATION_MODEL=Qwen/Qwen3.6-35B-A3B
GENAI_FLASH_MODEL=Qwen/Qwen3.6-35B-A3B
VERTEX_EMBEDDING_MODEL=gemini-embedding-2-preview

CLYPT_LOCAL_LLM_BASE_URL=http://127.0.0.1:8001/v1
CLYPT_LOCAL_LLM_MODEL=Qwen/Qwen3.6-35B-A3B
CLYPT_LOCAL_LLM_TIMEOUT_S=600
CLYPT_LOCAL_LLM_MAX_RETRIES=6
CLYPT_LOCAL_LLM_INITIAL_BACKOFF_S=1.0
CLYPT_LOCAL_LLM_MAX_BACKOFF_S=30.0
CLYPT_LOCAL_LLM_BACKOFF_MULTIPLIER=2.0
CLYPT_LOCAL_LLM_JITTER_RATIO=0.2
CLYPT_LOCAL_LLM_TEMPERATURE=0.0
CLYPT_LOCAL_LLM_TOP_P=1.0
CLYPT_LOCAL_LLM_TOP_K=40
CLYPT_LOCAL_LLM_MIN_P=0.0
CLYPT_LOCAL_LLM_PRESENCE_PENALTY=0.0
CLYPT_LOCAL_LLM_REPETITION_PENALTY=1.0

# SGLang service launch tuning (consumed by deploy_sglang_qwen_service.sh)
SG_PACKAGE_SPEC=sglang[all]
SG_SCHEDULE_POLICY=lpm
SG_CHUNKED_PREFILL_SIZE=8192
SG_MEM_FRACTION_STATIC=0.78
SG_CONTEXT_LENGTH=131072
SG_EXTRA_ARGS=

# -----------------------------------------------------------------------------
# Phase 2-4 local queue / worker
# -----------------------------------------------------------------------------
# Concurrency values are MAX in-flight LLM request caps per stage, validated
# against Qwen3.6-35B-A3B on H200 (2026-04-16 bench). Small videos won't
# saturate them; only large videos will scale up to these limits.
CLYPT_PHASE2_MERGE_MAX_CONCURRENT=16
CLYPT_PHASE2_BOUNDARY_MAX_CONCURRENT=16
CLYPT_SIGNAL_MAX_CONCURRENT=8
CLYPT_PHASE3_LOCAL_MAX_CONCURRENT=24
CLYPT_PHASE3_LONG_RANGE_TOP_K=2
CLYPT_PHASE3_LONG_RANGE_PAIRS_PER_SHARD=24
CLYPT_PHASE3_LONG_RANGE_MAX_CONCURRENT=24
CLYPT_PHASE4_SUBGRAPH_MAX_CONCURRENT=16
CLYPT_PHASE24_QUEUE_BACKEND=local_sqlite
CLYPT_PHASE24_LOCAL_QUEUE_PATH=/opt/clypt-phase1/repo/backend/outputs/phase24_local_queue.sqlite
CLYPT_PHASE24_LOCAL_POLL_INTERVAL_MS=500
CLYPT_PHASE24_LOCAL_LEASE_TIMEOUT_S=1800
CLYPT_PHASE24_LOCAL_MAX_INFLIGHT=1
CLYPT_PHASE24_LOCAL_MAX_REQUESTS_PER_WORKER=0
CLYPT_PHASE24_LOCAL_WORKER_ID=phase24-local-worker-1

# Fail-fast queue behavior (defaults).
CLYPT_PHASE24_LOCAL_RECLAIM_EXPIRED_LEASES=0
CLYPT_PHASE24_LOCAL_FAIL_FAST_ON_STALE_RUNNING=1

CLYPT_PHASE24_WORKER_SERVICE_NAME=clypt-phase24-local-worker
CLYPT_PHASE24_ENVIRONMENT=prod
CLYPT_PHASE24_QUERY_VERSION=v1
CLYPT_PHASE24_MAX_ATTEMPTS=3
CLYPT_DEBUG_SNAPSHOTS=0

CLYPT_PHASE24_FAILFAST_PREEMPTION_THRESHOLD=0
CLYPT_PHASE24_FAILFAST_P95_LATENCY_MS=0
CLYPT_PHASE24_BLOCK_ON_PHASE1_ACTIVE=0
# CLYPT_PHASE24_FFMPEG_DEVICE / CLYPT_PHASE24_NODE_MEDIA_MAX_CONCURRENT are
# no longer consumed on the H200 — node-media prep runs on the RTX audio host.

# Optional signal-model pins used in the working H200 host config.
CLYPT_SIGNAL_LLM_MODEL_1=Qwen/Qwen3.6-35B-A3B
CLYPT_SIGNAL_LLM_MODEL_2=Qwen/Qwen3.6-35B-A3B
CLYPT_SIGNAL_LLM_MODEL_3=Qwen/Qwen3.6-35B-A3B
CLYPT_SIGNAL_LLM_MODEL_5=Qwen/Qwen3.6-35B-A3B
CLYPT_SIGNAL_LLM_MODEL_9=Qwen/Qwen3.6-35B-A3B
CLYPT_SIGNAL_LLM_MODEL_10=Qwen/Qwen3.6-35B-A3B
CLYPT_SIGNAL_LLM_MODEL_11=Qwen/Qwen3.6-35B-A3B

# -----------------------------------------------------------------------------
# Caches / persistence
# -----------------------------------------------------------------------------
CLYPT_SPANNER_INSTANCE=clypt-spanner-v3
CLYPT_SPANNER_DATABASE=clypt-graph-db-v3

CLYPT_PHASE1_CACHE_HOME=/opt/clypt-phase1/.cache
XDG_CACHE_HOME=/opt/clypt-phase1/.cache
TORCH_HOME=/opt/clypt-phase1/.cache/torch
HF_HOME=/opt/clypt-phase1/.cache/huggingface
